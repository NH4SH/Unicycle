# Database
# Pooled runtime connection string from Neon
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLED-HOST.neon.tech/neondb?sslmode=require"
# Direct connection string from Neon for Prisma Migrate / CLI
DIRECT_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
DEV_AUTH_BYPASS="false"
TEST_AUTH_BYPASS="false"
TEST_AUTH_BYPASS_CODE=""

# Email magic links
# Optional single-string SMTP URL alternative:
# EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_SECURE="false"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="UniCycle <no-reply@example.com>"

# UploadThing
UPLOADTHING_TOKEN=""
